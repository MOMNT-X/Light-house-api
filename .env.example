# ─── App ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_VERSION=v1

# ─── Database (Supabase) ────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Auth / JWT ────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-another-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OPay ──────────────────────────────────────────
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_WEBHOOK_SECRET=
OPAY_BASE_URL=https://cashier.opayweb.com/api/v1

# ─── Discord ───────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM="Light House Logistics <noreply@lighthouselogistics.com>"

# ─── Supabase Storage ──────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=

# ─── Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60
AUTH_THROTTLE_LIMIT=5

# ─── Feature Flags ─────────────────────────────────
ENABLE_DELIVERY_ZONE_CHECK=true
SERVICE_CHARGE_PERCENT=2.5
